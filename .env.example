# STS2 mod ビルド・インストール設定
# このファイルをコピーして .env を作成し、自分の環境に合わせて編集してください。
# cp .env.example .env

# ---- macOS arm64 (Apple Silicon / Steam) ----
export STS2_DATA_DIR="$HOME/Library/Application Support/Steam/steamapps/common/Slay the Spire 2/SlayTheSpire2.app/Contents/Resources/data_sts2_macos_arm64"
export STS2_MODS_DIR="$HOME/Library/Application Support/Steam/steamapps/common/Slay the Spire 2/SlayTheSpire2.app/Contents/MacOS/mods"

# ---- macOS x86_64 (Intel / Steam) ----
# export STS2_DATA_DIR="$HOME/Library/Application Support/Steam/steamapps/common/Slay the Spire 2/SlayTheSpire2.app/Contents/Resources/data_sts2_macos_x86_64"
# export STS2_MODS_DIR="$HOME/Library/Application Support/Steam/steamapps/common/Slay the Spire 2/SlayTheSpire2.app/Contents/MacOS/mods"

# ---- Windows (Steam / デフォルトインストール先) ----
# export STS2_DATA_DIR="C:/Program Files (x86)/Steam/steamapps/common/Slay the Spire 2/data_sts2_windows_x86_64"
# export STS2_MODS_DIR="C:/Program Files (x86)/Steam/steamapps/common/Slay the Spire 2/mods"

# ---- バックエンドサーバURL (任意) ----
# 注: ゲーム本体は自分の shell の env を引き継がないため、本番運用では
# mods/StsStats/config.json の "backend_url" で上書きするのが推奨。
# ここで設定するのは開発（ターミナルからゲームを起動する場合）用。
# 空文字を設定すると HTTP送信を無効化し、JSONLログのみ動作する。
# export STS_STATS_BACKEND_URL="http://localhost:8080"
